// ==UserScript==
// @name         ChatGPT Lag Fixer
// @version      1.0
// @description  Show messages in batches
// @match        https://chatgpt.com/*
// @grant        GM_getValue
// @grant        GM_setValue
// @grant        GM_registerMenuCommand
// ==/UserScript==

(function(){
'use strict'

let s = GM_getValue("batchSize", 25), o = 0, b = null, st = null
let d = matchMedia('(prefers-color-scheme: dark)').matches, ll = 0, lv = -1
let mo = null

function q() { return document.querySelectorAll('article[data-testid^="conversation-turn-"]') }

function trim() {
  let a = q(), l = a.length
  if (!l || !st) return
  let v = Math.min((o + 1) * s, l), h = l - v
  if (l === ll && v === lv) return
  ll = l; lv = v

  st.textContent = `article[data-testid^="conversation-turn-"]{display:none}
article[data-testid^="conversation-turn-"]:nth-last-child(-n+${v}){display:block}`

  if (b && b.parentNode) b.parentNode.removeChild(b)

  if (v < l) {
    if (!b) {
      b = document.createElement('div')
      b.style.cssText = "display:flex;justify-content:center;margin:16px 0"
      let x = document.createElement('button')
      x.style.cssText = `padding:8px 14px;background:transparent;color:${d ? 'white' : 'black'};border:1px solid ${d ? 'white' : 'black'};border-radius:18px;cursor:pointer`
      x.onclick = () => { o++; trim() }
      b.appendChild(x)
    }
    let f = a[l - v]
    if (f && f.parentNode) {
      let btn = b.firstChild
      btn.innerText = `Show ${Math.min(s,h)} more → ${h} left`
      requestAnimationFrame(() => {
        if (f.parentNode && b.parentNode !== f.parentNode) f.parentNode.insertBefore(b, f)
      })
    }
  }
}

function init() {
  if (st) return
  st = document.createElement('style')
  document.head && document.head.appendChild(st)
  trim()
  let container = document.querySelector('[data-testid^="conversation-container"]') || document.body
  mo = new MutationObserver(trim)
  mo.observe(container, { childList: true, subtree: true })
}

GM_registerMenuCommand("Set Batch Size", () => {
  let i = prompt("Enter batch size (5-100):", s), n = parseInt(i, 10)
  if (!isNaN(n) && n >= 5 && n <= 100) { GM_setValue("batchSize", n); s = n; alert(`Batch size set to ${n}. Reload page to apply.`) }
})

document.addEventListener('DOMContentLoaded', init)
window.addEventListener('load', init)
})();
